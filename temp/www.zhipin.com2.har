el\":0},{\"code\":404,\"name\":\"5000-10000\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":405,\"name\":\"10000-20000\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":406,\"name\":\"20000-50000\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":407,\"name\":\"50000以上\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0}],\"lstRelationOrigin\":[\"All\",\"GeekInit\",\"BossInit\",\"ColleagueRecommend\",\"FullResume\",\"HasPhone\",\"HasWechat\",\"CanContact\",\"LIVE_DELIVERY\",\"ITEM_SOURCE\"],\"rdcGrayUser\":false,\"newWeeklyRecruit\":true,\"userExtra\":{\"id\":5383002,\"userId\":50782033,\"identityType\":1,\"comId\":122506,\"brandId\":1265022,\"joinComTime\":1575449164000,\"companyFullName\":\"华为技术有限公司\",\"title\":\"HR\",\"eventTime\":1774315251774,\"status\":0,\"addTime\":1554880987000,\"location\":0,\"industryCategory\":null,\"scaleCategory\":null,\"locationSecCategroy\":null,\"userTag\":0,\"industryCostTag\":0,\"certStatus\":3,\"limitedDetailUrl\":\"/mpa/html/mix/limit-boss/intro\",\"proxyBoss\":false,\"freezeUser\":false},\"onlineJobList\":[],\"projectAiFlag\":false,\"bossPowerTypeForLive\":0,\"runChat\":true,\"isManager\":false,\"isFreeComAdmin\":false,\"tag\":0,\"brand\":{\"id\":1265022,\"name\":\"CloudBU\",\"logo\":\"https://img.bosszhipin.com/beijin/upload/com/logo/20241204/7b5b554d84f9729c96d4fe255c2e24568d3bf6d9d699d85e93ee154a64ef0cce266c3614f4d101d2.png.webp\",\"industry\":100020,\"scale\":306,\"website\":\"\",\"stage\":801,\"certificate\":1,\"complete\":true,\"introduce\":\"华为云是华为的云服务品牌，将华为30多年在ICT领域的技术积累和产品解决方案开放，提供稳定可靠，安全可信、可持续发展的云服务。\\n\\n华为云践行“一切皆服务”的战略，不断提升产品竞争力，成为云服务的领先者。目前，华为云在国内十大研究所设立了研发中心，并与国内顶尖的科研院校展开合作，不断增强云计算领域的创新能力和核心竞争力。在这里，您将接触云原生2.0全栈技术，深度参与全场景业务，站在技术的最前沿，引领云时代!\",\"briefIntroduce\":\"华为云提供稳定可靠，安全可信的云服务。\",\"addTime\":1511443798000,\"updateTime\":1733288036000,\"editStatus\":2,\"brandType\":0,\"controlLabel\":\"\",\"industryName\":\"互联网\",\"scaleName\":\"10000人以上\",\"stageName\":\"未融资\",\"bossCount\":0,\"jobCount\":0,\"logoAuditStatus\":1,\"websiteAuditStatus\":1,\"introduceAuditStatus\":1,\"multiIndustryCode\":null,\"multiIndustryName\":null,\"hide\":0,\"source\":0,\"similarRecommendSwitch\":0,\"hideIndustryInfo\":0,\"hideScaleInfo\":false,\"brandId\":1265022,\"rejected\":false},\"isAgentRecruit\":false,\"brandMgrGray\":false,\"innerHr\":false,\"clientId\":\"783ab411-6a5b-4d92-83ca-3984cd34d434\",\"chl\":\"\",\"degree\":[{\"code\":201,\"name\":\"不限\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":209,\"name\":\"初中及以下\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":208,\"name\":\"中专/中技\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":206,\"name\":\"高中\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":202,\"name\":\"大专\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":203,\"name\":\"本科\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":204,\"name\":\"硕士\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0},{\"code\":205,\"name\":\"博士\",\"subLevelModelList\":null,\"firstChar\":null,\"rank\":0,\"parentCode\":0,\"gParentCode\":0,\"level\":0}],\"mu\":\"\",\"isAdmin\":false,\"enterpriseCanEditPage\":false,\"allowShowLiveApplyEntrance\":false,\"showEvaluationTab\":false,\"hasInterview\":false,\"isGrayCompany\":true,\"bestRecruiterRedPointFlag\":1,\"innerInterview\":false,\"bestRecruiterFlag\":1}},\"/wapi/